<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" spacing="20" styleClass="dashboard-container"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.RapoarteController">

    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label styleClass="dashboard-title" text="Rapoarte si Statistici Manageriale" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="An:" />
        <ComboBox fx:id="yearCombo" prefWidth="140"/>
        <Label style="-fx-opacity: 0.75;" text="(rapoartele sunt filtrate pe anul selectat)" />
    </HBox>

    <HBox alignment="CENTER" spacing="20">
        <Button onAction="#showTopClients" styleClass="btn-primary" text="Top Clienti VIP" />
        <Button onAction="#showRevenuePerRoom" styleClass="btn-primary" text="Venituri per Sala" />
    </HBox>

    <HBox alignment="CENTER" spacing="20">
        <Button onAction="#showIdleEmployees" styleClass="btn-secondary" text="Angajati Fara Activitate" />
        <Button onAction="#showTopServices" styleClass="btn-secondary" text="Cele mai Populare Servicii" />
    </HBox>

    <HBox alignment="CENTER" spacing="20">
        <Button onAction="#showBusyEmployees" styleClass="btn-secondary" text="Angajati peste medie" />
        <Button onAction="#showReturningClients" styleClass="btn-secondary" text="Clienti recurenti" />
        <Button onAction="#showServiceRevenueAboveAvg" styleClass="btn-secondary" text="Venit servicii peste medie" />
    </HBox>

    <Label fx:id="reportTitleLabel"
           style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 10 0 0 0;"
           text="Selectati un raport de mai sus..." />

    <TableView fx:id="dynamicTable" styleClass="table-view" VBox.vgrow="ALWAYS">
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT">
        <Button onAction="#handleClose" styleClass="quick-action-button-secondary" text="Inchide Panoul" />
    </HBox>

</VBox>
