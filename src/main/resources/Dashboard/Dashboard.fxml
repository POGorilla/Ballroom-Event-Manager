<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="controller.DashboardController" spacing="20" styleClass="dashboard-container">
    <padding>
        <Insets top="10" right="20" bottom="20" left="20" />
    </padding>

    <children>
        <Label text="Dashboard General" styleClass="dashboard-title" />

        <HBox spacing="20">
            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                <Label text="Evenimente Active (Planificate)" styleClass="kpi-title" />
                <Label fx:id="kpiActiveEvents" text="-" styleClass="kpi-value" />
            </VBox>

            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                <Label text="Evenimente Luna Curenta" styleClass="kpi-title" />
                <Label fx:id="kpiEventsMonth" text="-" styleClass="kpi-value-secondary" />
            </VBox>

            <VBox styleClass="kpi-card" HBox.hgrow="ALWAYS">
                <Label text="Total Clienti Inregistrati" styleClass="kpi-title" />
                <Label fx:id="kpiTotalClients" text="-" styleClass="kpi-value" />
            </VBox>
        </HBox>

        <GridPane hgap="20" vgap="20" VBox.vgrow="ALWAYS">
            <columnConstraints>
                <ColumnConstraints percentWidth="65.0" />
                <ColumnConstraints percentWidth="35.0" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints vgrow="SOMETIMES" />
                <RowConstraints vgrow="SOMETIMES" />
            </rowConstraints>

            <VBox styleClass="section-card" spacing="10" GridPane.columnIndex="0" GridPane.rowSpan="2" VBox.vgrow="ALWAYS">
                <Label text="Urmatoarele 10 Evenimente Planificate" styleClass="section-title" />
                <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="colEventData" text="Data" prefWidth="100" />
                        <TableColumn fx:id="colEventNume" text="Eveniment" prefWidth="200" />
                        <TableColumn fx:id="colEventClient" text="Client" prefWidth="150" />
                        <TableColumn fx:id="colEventSala" text="Sala" prefWidth="120" />
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="section-card" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="0">
                <Label text="Actiuni Rapide" styleClass="section-title" />
                <Button fx:id="btnAddEvent" text="Adauga Eveniment Nou"
                        styleClass="quick-action-button" maxWidth="Infinity"
                        onAction="#handleAddEvent" />

                <Button fx:id="btnAddClient" text="Adauga Client Nou"
                        styleClass="quick-action-button-secondary" maxWidth="Infinity"
                        onAction="#handleAddClient" />

                <VBox style="-fx-border-color: #555; -fx-border-width: 1 0 0 0; -fx-margin: 10 0 0 0;" />

                <Button fx:id="btnContactClienti" text="Contact Clienti"
                        styleClass="nav-button" maxWidth="Infinity"
                        onAction="#handleContactClienti" />

                <Button fx:id="btnContactSupervizori" text="Contact Supervizori"
                        styleClass="nav-button" maxWidth="Infinity"
                        onAction="#handleContactSupervizori" />
            </VBox>

            <VBox styleClass="section-card" spacing="10" GridPane.columnIndex="1" GridPane.rowIndex="1" VBox.vgrow="ALWAYS">
                <Label text="Venituri ultimele 12 luni" styleClass="section-title" />
                <BarChart fx:id="revenueChart" VBox.vgrow="ALWAYS" legendVisible="false">
                    <xAxis>
                        <CategoryAxis label="Luna" fx:id="xAxis" />
                    </xAxis>
                    <yAxis>
                        <NumberAxis label="Venituri (RON)" />
                    </yAxis>
                </BarChart>
            </VBox>

        </GridPane>
    </children>
</VBox>
